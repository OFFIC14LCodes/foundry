{
  "rewrites": [
    {
      "source": "/api/tts-usage",
      "destination": "/api/tts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/admin-daily-summary",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/send-monday-briefings",
      "schedule": "0 9 * * 1"
    }
  ],
  "functions": {
    "api/send-monday-briefings.js": {
      "maxDuration": 300
    },
    "api/admin-daily-summary.js": {
      "maxDuration": 120
    }
  }
}
